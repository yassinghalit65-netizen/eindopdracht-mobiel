<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BMI Calculator</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <!-- TITEL -->
        <h1 id="title">📊 BMI Calculator</h1>
        
        <!-- TAAL KNOPPEN -->
        <div class="language-switch">
            <button class="lang-btn active" onclick="setLanguage('nl')">🇳🇱 NL</button>
            <button class="lang-btn" onclick="setLanguage('en')">🇬🇧 EN</button>
        </div>
        
        <!-- INPUT -->
        <div class="input-group">
            <label id="labelLength">📏 Lengte (cm)</label>
            <input type="number" id="length" placeholder="bijv. 175">
        </div>
        
        <div class="input-group">
            <label id="labelWeight">⚖️ Gewicht (kg)</label>
            <input type="number" id="weight" placeholder="bijv. 70">
        </div>
        
        <button id="saveBtn" onclick="berekenBMI()">🧮 Bereken BMI</button>
        
        <!-- RESULTAAT -->
        <div id="resultCard" style="display: none;">
            <h2 id="resultTitle">📊 Jouw BMI</h2>
            <div id="bmiValue" class="bmi-value">-</div>
            <div id="bmiCategory"></div>
            <p id="adviceText"></p>
        </div>
        
        <!-- EXPORT/IMPORT KNOPPEN -->
        <div class="export-buttons">
            <button onclick="exportData()" class="export-btn">💾 Exporteer JSON</button>
            <button onclick="document.getElementById('importFile').click()" class="import-btn">📂 Importeer JSON</button>
            <input type="file" id="importFile" accept=".json" style="display: none" onchange="importData(event)">
        </div>
        
        <!-- METINGEN LIJST -->
        <div class="history">
            <h2 id="historyTitle">📋 Geschiedenis</h2>
            <div id="measurementsList"></div>
            <button onclick="clearAll()" class="clear-btn">🗑️ Alles wissen</button>
        </div>
    </div>
    
    <script src="/js/app.js"></script>
</body>
</html>